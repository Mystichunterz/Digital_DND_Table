# Normalise text files to LF in the repo and on checkout (silences the
# CRLF warnings on Windows; v2 / scripts are all LF on disk anyway).
* text=auto eol=lf

# Binary assets — never touch line endings.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.db    binary
